{
	"$schema": "https://unpkg.com/oxlint/configuration_schema.json",
	"ignorePatterns": [
		"dist",
		"target",
		"node_modules",
		"coverage",
		".git",
		".claude/settings.local.json",
		"nix/models-dev-gen.ts"
	],
	"jsPlugins": ["./nix/oxlint-plugin.js"],
	"options": {
		"typeAware": true,
		"typeCheck": true
	},
	"rules": {
		"ccusage/no-server-actions": "error"
	}
}
