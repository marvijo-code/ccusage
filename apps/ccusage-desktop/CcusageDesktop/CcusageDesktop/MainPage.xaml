<Page x:Class="CcusageDesktop.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:CcusageDesktop"
      Background="#0C1016">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid x:Name="HeaderBar" Grid.Row="0" Padding="28,18,28,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
        <Border Width="42" Height="42" CornerRadius="11">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#4CC2A9" Offset="0" />
              <GradientStop Color="#7C5CFF" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <TextBlock Text="$_" FontFamily="Cascadia Mono" FontSize="17" FontWeight="Bold"
                     Foreground="#0C1016" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <StackPanel VerticalAlignment="Center" Spacing="1">
          <StackPanel Orientation="Horizontal" Spacing="9">
            <TextBlock Text="ccusage" FontSize="21" FontWeight="Bold" Foreground="#E6EDF3" />
            <Border Background="#1C2530" CornerRadius="5" Padding="7,2,7,3" VerticalAlignment="Center">
              <TextBlock Text="DESKTOP" FontSize="10" FontWeight="SemiBold" Foreground="#4CC2A9" />
            </Border>
          </StackPanel>
          <TextBlock Text="Token &amp; cost analytics across your coding agents"
                     FontSize="12" Foreground="#8B949E" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center" Spacing="1">
          <TextBlock x:Name="UpdatedText" Text="" FontSize="12" Foreground="#8B949E"
                     HorizontalAlignment="Right" />
          <TextBlock x:Name="StatusText" Text="" FontSize="11" Foreground="#58636F"
                     HorizontalAlignment="Right" />
        </StackPanel>
        <Button x:Name="RefreshButton" Click="OnRefreshClick" Padding="16,9"
                Background="#1C2530" BorderBrush="#2A3542" BorderThickness="1" CornerRadius="9">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ProgressRing x:Name="RefreshSpinner" Width="14" Height="14" Visibility="Collapsed"
                          IsActive="False" Foreground="#4CC2A9" />
            <TextBlock x:Name="RefreshLabel" Text="Refresh" FontSize="13" FontWeight="SemiBold"
                       Foreground="#E6EDF3" />
          </StackPanel>
        </Button>
        <Button Click="OnCollapseClick" Padding="13,9" ToolTipService.ToolTip="Collapse to mini widget"
                Background="#1C2530" BorderBrush="#2A3542" BorderThickness="1" CornerRadius="9">
          <TextBlock Text="Mini" FontSize="13" FontWeight="SemiBold" Foreground="#8B949E" />
        </Button>
      </StackPanel>
    </Grid>

    <!-- Tab bar -->
    <StackPanel x:Name="TabBar" Grid.Row="1" Orientation="Horizontal" Spacing="8"
                Padding="28,6,28,12" />

    <!-- Active tab content -->
    <Grid x:Name="ContentHost" Grid.Row="2" />
  </Grid>
</Page>
